# Server Configuration
IP_ADDRESS=10.10.7.44
NODE_ENV=development
PORT=5002

# Database Configuration
DATABASE_URL=mongodb://localhost:27017/duty_hour_app
# Or use MongoDB Atlas:
# DATABASE_URL=mongodb+srv://username:password@cluster.mongodb.net/database_name?retryWrites=true&w=majority&appName=Cluster0

# Bcrypt Configuration
BCRYPT_SALT_ROUNDS=12

# JWT Configuration
JWT_SECRET=your_jwt_secret_key_here_min_32_characters_for_security
JWT_EXPIRE_IN=30d

# Stripe Configuration
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_stripe_webhook_secret_here

# Stripe URLs
STRIPE_PAYMENT_SUCCESS_URL=http://localhost:3000/payment-success

# Employee Creation After Payment URLs
EMPLOYEE_CREATION_AFTER_PAYMENT_LINK=http://localhost:3000/employee-management
EMPLOYEE_CREATION_AFTER_PAYMENT_LINK_Failed=http://localhost:3000/employee-management/add-employee

# Bulk Employee Creation After Payment URLs
BULK_EMPLOYEE_CREATION_AFTER_PAYMENT_LINK=http://localhost:3000/employee-management/bulk-upload
BULK_EMPLOYEE_CREATION_AFTER_PAYMENT_LINK_Failed=http://localhost:3000/employee-management/bulk-upload

# Email Configuration (NodeMailer)
EMAIL_FROM=noreply@company.com
EMAIL_USER=your_email@gmail.com
EMAIL_HOST=smtp.gmail.com
EMAIL_PASS=your_app_password_here
EMAIL_PORT=587

# Super Admin Credentials (Initial Setup)
SUPER_ADMIN_EMAIL=admin@gmail.com
SUPER_ADMIN_PASSWORD=admin@123